# Базові пакети для стабільної роботи devcontainer image.
ca-certificates
curl
locales
sudo
tzdata
ssh
git

# C++ toolchain і language server для редактора.
gcc
clang
clangd
clang-tidy

# Runtime-бібліотеки Clang sanitizer-ів і symbolizer для читабельного ASan/UBSan output.
libclang-rt-18-dev
llvm-18

# Крос-тулчейн для ARM64-пристроїв: RPi4, Radxa ROCK 5B+, Jetson.
g++-aarch64-linux-gnu

# Інструменти для заняття 2.4: локальний і remote debug, memory diagnostics.
gdb
gdbserver
gdb-multiarch
valgrind

# Інструменти збірки і форматери, які використовуються в лекціях та CI.
make
cmake
clang-format
cmake-format
ninja-build

# ROS 2 інструменти для демо блоку 5: colcon workspace, ament_auto і graph GUI.
python3-colcon-common-extensions
ros-jazzy-ament-cmake-auto
ros-jazzy-rqt-graph

# CycloneDDS використовується як default RMW для стабільнішого discovery
# у devcontainer.
ros-jazzy-rmw-cyclonedds-cpp
